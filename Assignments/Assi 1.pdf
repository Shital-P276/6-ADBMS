1 0 0 1 40 348 Tm (    phone_no  phone_set) Tj
1 0 0 1 40 336 Tm (\)) Tj
1 0 0 1 40 324 Tm (NESTED TABLE phone_no STORE AS author_phone_nt;) Tj
1 0 0 1 40 312 Tm () Tj
1 0 0 1 40 300 Tm (CREATE TABLE book \() Tj
1 0 0 1 40 288 Tm (    isbn      NUMBER PRIMARY KEY,) Tj
1 0 0 1 40 276 Tm (    title     VARCHAR2\(30\),) Tj
1 0 0 1 40 264 Tm (    author_id author_id_array,) Tj
1 0 0 1 40 252 Tm (    category  VARCHAR2\(20\),) Tj
1 0 0 1 40 240 Tm (    publisher publisher_type,) Tj
1 0 0 1 40 228 Tm (    keywords  keyword_set,) Tj
1 0 0 1 40 216 Tm (    price     NUMBER\(10,2\)) Tj
1 0 0 1 40 204 Tm (\)) Tj
1 0 0 1 40 192 Tm (NESTED TABLE keywords STORE AS book_keywords_nt;) Tj
1 0 0 1 40 180 Tm () Tj
1 0 0 1 40 168 Tm (CREATE TABLE customer \() Tj
1 0 0 1 40 156 Tm (    customer_id VARCHAR2\(10\) PRIMARY KEY,) Tj
1 0 0 1 40 144 Tm (    name        name_type,) Tj
1 0 0 1 40 132 Tm (    phone_no    phone_set) Tj
1 0 0 1 40 120 Tm (\)) Tj
1 0 0 1 40 108 Tm (NESTED TABLE phone_no STORE AS customer_phone_nt;) Tj
1 0 0 1 40 96 Tm () Tj
1 0 0 1 40 84 Tm (CREATE TABLE book_sale \() Tj
1 0 0 1 40 72 Tm (    sale_id     VARCHAR2\(10\) PRIMARY KEY,) Tj
1 0 0 1 40 60 Tm (    customer_id VARCHAR2\(10\) REFERENCES customer\(customer_id\),) Tj
1 0 0 1 40 48 Tm (    isbn        NUMBER REFERENCES book\(isbn\)) Tj
ET
endstream
