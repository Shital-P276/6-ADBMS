10 0 obj
<< /Length 1397 >>
stream
BT
/F1 10 Tf
1 0 0 1 40 792 Tm (SELECT c.name.fname || ' ' || c.name.lname AS customer_name,) Tj
1 0 0 1 40 780 Tm (       b.title,) Tj
1 0 0 1 40 768 Tm (       b.publisher.pub_name AS publisher_name) Tj
1 0 0 1 40 756 Tm (FROM book_sale bs) Tj
1 0 0 1 40 744 Tm (JOIN customer c ON c.customer_id = bs.customer_id) Tj
1 0 0 1 40 732 Tm (JOIN book b ON b.isbn = bs.isbn) Tj
1 0 0 1 40 720 Tm (WHERE UPPER\(b.publisher.branch\) IN \('UK','US'\)) Tj
1 0 0 1 40 708 Tm (ORDER BY c.name.lname, c.name.fname;) Tj
1 0 0 1 40 696 Tm () Tj
1 0 0 1 40 684 Tm (-- Q4: Distinct categories and number of books per category) Tj
1 0 0 1 40 672 Tm (SELECT b.category,) Tj
1 0 0 1 40 660 Tm (       COUNT\(*\) AS no_of_books) Tj
1 0 0 1 40 648 Tm (FROM book b) Tj
1 0 0 1 40 636 Tm (GROUP BY b.category) Tj
1 0 0 1 40 624 Tm (ORDER BY b.category;) Tj
1 0 0 1 40 612 Tm () Tj
1 0 0 1 40 600 Tm (-- Q5: Number of books sold written by each author \(group by first name\)) Tj
1 0 0 1 40 588 Tm (SELECT a.name.fname AS author_first_name,) Tj
1 0 0 1 40 576 Tm (       COUNT\(*\) AS books_sold) Tj
1 0 0 1 40 564 Tm (FROM book_sale bs) Tj
1 0 0 1 40 552 Tm (JOIN book b ON b.isbn = bs.isbn) Tj
1 0 0 1 40 540 Tm (JOIN TABLE\(b.author_id\) aid ON 1=1) Tj
1 0 0 1 40 528 Tm (JOIN author a ON a.author_id = aid.COLUMN_VALUE) Tj
1 0 0 1 40 516 Tm (GROUP BY a.name.fname) Tj
1 0 0 1 40 504 Tm (ORDER BY a.name.fname;) Tj
ET
endstream
