1 0 0 1 40 312 Tm () Tj
1 0 0 1 40 300 Tm (-- Q1: List all titles with ISBN and author full name) Tj
1 0 0 1 40 288 Tm (SELECT b.isbn,) Tj
1 0 0 1 40 276 Tm (       b.title,) Tj
1 0 0 1 40 264 Tm (       a.name.fname || ' ' || a.name.lname AS author_name) Tj
1 0 0 1 40 252 Tm (FROM book b,) Tj
1 0 0 1 40 240 Tm (     TABLE\(b.author_id\) aid,) Tj
1 0 0 1 40 228 Tm (     author a) Tj
1 0 0 1 40 216 Tm (WHERE a.author_id = aid.COLUMN_VALUE) Tj
1 0 0 1 40 204 Tm (ORDER BY b.isbn, author_name;) Tj
1 0 0 1 40 192 Tm () Tj
1 0 0 1 40 180 Tm (-- Q2: Customers who purchased books published by Tata McGraw Hill) Tj
1 0 0 1 40 168 Tm (SELECT DISTINCT) Tj
1 0 0 1 40 156 Tm (       c.customer_id,) Tj
1 0 0 1 40 144 Tm (       c.name.fname || ' ' || c.name.lname AS customer_name) Tj
1 0 0 1 40 132 Tm (FROM book_sale bs) Tj
1 0 0 1 40 120 Tm (JOIN customer c ON c.customer_id = bs.customer_id) Tj
1 0 0 1 40 108 Tm (JOIN book b ON b.isbn = bs.isbn) Tj
1 0 0 1 40 96 Tm (WHERE UPPER\(b.publisher.pub_name\) = 'TATA MCGRAW HILL') Tj
1 0 0 1 40 84 Tm (ORDER BY customer_name;) Tj
1 0 0 1 40 72 Tm () Tj
1 0 0 1 40 60 Tm (-- Q3: Customers who purchased books published in UK or US,) Tj
1 0 0 1 40 48 Tm (--     include title and publisher name, order by customer last name) Tj
ET
endstream
